[Unit]
Description=ELD Trip Django API (gunicorn)
After=network.target

[Service]
WorkingDirectory=__APP_DIR__
Environment="PATH=__APP_DIR__/venv/bin"
ExecStart=__APP_DIR__/venv/bin/gunicorn --workers 3 --bind 0.0.0.0:8000 config.wsgi:application
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
